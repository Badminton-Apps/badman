# =============================================================================
# Database
# =============================================================================
# Use DB_* for all environments. For migrations/seeds, load the target env
# (e.g. dotenv -e .env.staging) and set NODE_ENV to match.
DB_IP=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_DIALECT=

# =============================================================================
# Cache (Redis)
# =============================================================================
# Set DB_CACHE=true in production to offload Nest cache-manager to Redis.
DB_CACHE=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# External APIs
# =============================================================================

# Toernooi.nl (VR)
VR_API=
VR_API_USER=
VR_API_PASS=

# TWIZZIT
TWIZZIT_API=
TWIZZIT_API_USER=
TWIZZIT_API_PASS=

# Render
RENDER_API_URL=
RENDER_API_KEY=

# Apollo GraphQL
APOLLO_GRAPH_REF=

# =============================================================================
# Auth (Auth0)
# =============================================================================
AUTH0_ISSUER_URL=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
CLIENT_URL=

# =============================================================================
# Mail
# =============================================================================
MAIL_HOST=
MAIL_USER=
MAIL_PASS=

# =============================================================================
# Push (Web Push / VAPID)
# =============================================================================
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# =============================================================================
# Seed (development / testing)
# =============================================================================
SEED_USER_EMAIL=test@testtest.be
SEED_FIRST_NAME=User
SEED_LAST_NAME=Userson
SEED_GENDER=M
