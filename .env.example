# Database: use DB_* for all environments. For migrations/seeds, load the target env (e.g. dotenv -e .env.staging) and set NODE_ENV to match.
DB_IP=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_DIALECT=

# Set to true in production to offload Nest cache-manager to Redis (requires REDIS_HOST, REDIS_PORT, REDIS_PASSWORD)
DB_CACHE=false
REDIS_HOST=redis
REDIS_PORT=6379

AUTH0_ISSUER_URL=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
CLIENT_URL=

MAIL_PASS=
MAIL_USER=
MAIL_HOST=

VR_API=
VR_API_USER=
VR_API_PASS=

VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=


SEED_USER_EMAIL="test@testtest.be"
SEED_FIRST_NAME="User"
SEED_LAST_NAME="Userson" 
SEED_GENDER="M" 