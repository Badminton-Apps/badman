# =============================================================================
# Database
# =============================================================================
# Use DB_* for all environments. For migrations/seeds, load the target env
# (e.g. dotenv -e .env.staging) and set NODE_ENV to match.
DB_IP=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_DIALECT=

# =============================================================================
# Cache (Redis)
# =============================================================================
# Set DB_CACHE=true in production to offload Nest cache-manager to Redis.
DB_CACHE=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# External APIs
# =============================================================================

# Toernooi.nl (VR)
VR_API=
VR_API_USER=
VR_API_PASS=

# TWIZZIT
# Used by the legacy sync code AND by the live-mode test suite of
# libs/integrations/twizzit-client (when RUN_TWIZZIT_LIVE_TESTS=1).
# TWIZZIT_API is optional — the client defaults to https://app.twizzit.com/v2/api.
TWIZZIT_API=
TWIZZIT_API_USER=
TWIZZIT_API_PASS=
# Set to 1 to enable the opt-in live-mode test suite in
# libs/integrations/twizzit-client (default unset: live tests are skipped).
# Run: RUN_TWIZZIT_LIVE_TESTS=1 npx nx test integrations-twizzit-client \
#        --skip-nx-cache --testPathPattern '\.live\.spec\.ts$'
RUN_TWIZZIT_LIVE_TESTS=

# Twizzit Shadow Sync worker (apps/worker/twizzit-shadow)
# Set TWIZZIT_SHADOW_RUN_ON_BOOT=1 to trigger full backfill on worker boot.
TWIZZIT_SHADOW_RUN_ON_BOOT=
# Delay between pages (ms). Default: 250.
TWIZZIT_SHADOW_INTER_PAGE_DELAY_MS=250
# Records per page. Default: 100.
TWIZZIT_SHADOW_PAGE_SIZE=100
# Set to 1 to force a full re-fetch even if last completed run < 7 days ago.
TWIZZIT_SHADOW_FORCE_FULL_REFETCH=
# Shadow worker reuses TWIZZIT_API_USER / TWIZZIT_API_PASS above.
TWIZZIT_ORGANIZATION_ID=
# Port for shadow worker health endpoint. Default: 5006.
WORKER_TWIZZIT_SHADOW_PORT=5006

# Render
RENDER_API_URL=
RENDER_API_KEY=

# Apollo GraphQL
APOLLO_GRAPH_REF=

# =============================================================================
# Auth (Auth0)
# =============================================================================
AUTH0_ISSUER_URL=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
CLIENT_URL=

# =============================================================================
# Mail
# =============================================================================
MAIL_HOST=
MAIL_USER=
MAIL_PASS=

# =============================================================================
# Push (Web Push / VAPID)
# =============================================================================
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# =============================================================================
# Seed (development / testing)
# =============================================================================
SEED_USER_EMAIL=test@testtest.be
SEED_FIRST_NAME=User
SEED_LAST_NAME=Userson
SEED_GENDER=M

SEED_ADMIN_USER_EMAIL=admin@testtest.be
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Adminson
SEED_ADMIN_GENDER=M
SEED_ADMIN_USER_AUTH0_SUB=
