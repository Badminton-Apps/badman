# Overrides for running API + worker locally with PRODUCTION database.
# Copy to .env.prod-db and fill in values. Do NOT commit .env.prod-db (it may contain secrets).
# Load .env.prod-db after .env so these values take precedence (see docs/enter-scores-local-browser.md).
#
# Keep Redis local so jobs stay on your machine:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
#
# Point at production database (use full hostname, e.g. dpg-xxx.frankfurt-postgres.render.com):
# DB_IP=your-prod-db-host
# DB_PORT=5432
# DB_DATABASE=your-prod-db-name
# DB_USER=your-prod-db-user
# DB_PASSWORD=your-prod-db-password
# DB_SSL=true
# DB_DIALECT=postgres
#
# ------------------------------------------------------------------------------
# DEV ONLY - NEVER SET IN PRODUCTION.
# These allow unauthenticated queue-job requests (test script without JWT).
# Only active when NODE_ENV=development. Bypass is DISABLED in production/staging.
# ------------------------------------------------------------------------------
# DEV_ONLY_ALLOW_QUEUE_JOB_WITHOUT_AUTH=true
# DEV_ONLY_QUEUE_JOB_AS_PLAYER_ID=<player-uuid-with-change-job-permission>
